[Unit]
Description=Soulmane Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/soulmane
EnvironmentFile=%h/.local/share/soulmane/.env
ExecStart=%h/.local/share/soulmane/.venv/bin/python %h/.local/share/soulmane/bot.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
